<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.campusrunner.backend.order.dao.OrderStatusLogDao">

    <select id="findByOrderIdOrderByCreatedAtDesc"
            resultType="com.campusrunner.backend.order.entity.OrderStatusLog">
        SELECT id,
               order_id,
               from_status,
               to_status,
               operator_id,
               note,
               created_at
        FROM order_status_logs
        WHERE order_id = #{orderId}
        ORDER BY created_at DESC
    </select>
</mapper>
