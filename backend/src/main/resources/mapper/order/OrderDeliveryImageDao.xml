<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.campusrunner.backend.order.dao.OrderDeliveryImageDao">

    <select id="findByOrderIdOrderByCreatedAtDesc"
            resultType="com.campusrunner.backend.order.entity.OrderDeliveryImage">
        SELECT id,
               order_id,
               uploader_id,
               image_url,
               note,
               created_at
        FROM order_delivery_images
        WHERE order_id = #{orderId}
        ORDER BY created_at DESC
    </select>
</mapper>
